# Serve the static Nuxt output on port 80.
# Traefik (Coolify) terminates TLS and routes the domain here, so plain :80.
:80 {
	root * /srv
	encode gzip zstd

	# Long-cache hashed build assets (safe — filenames change on rebuild)
	@assets path /_nuxt/* /images/* *.svg *.jpg *.png *.webp *.avif *.woff2
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Don't cache HTML (so content updates show immediately)
	@html path *.html /
	header @html Cache-Control "public, max-age=0, must-revalidate"

	# Serve the matching index.html for clean URLs (/acerca → /acerca/index.html)
	# without an extra redirect; fall through to the 404 page otherwise.
	try_files {path} {path}/index.html

	file_server

	# Custom 404 page with a real 404 status
	handle_errors {
		@notFound expression {err.status_code} == 404
		rewrite @notFound /404.html
		file_server
	}
}
